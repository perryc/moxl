	)
	(text "SECTION: ANALOG SENSING\nADS1115: I2C 16-bit ADC @ addr 0x48\nAIN0: Battery 12V (Bottom 12V Bat)\nAIN1: Alternator current (ACS712 or shunt)\nAIN2: Fuel level (resistive float sender)\nAIN3: Battery Pack 24V (12V+12V) "
		(exclude_from_sim no)
		(at 252.476 24.892 0)
		(effects
			(font
				(size 1.5 1.5)
			)
		)
		(uuid "3805ff10-4abb-4e57-a38a-d1d93c839485")
	)
	(text "5V Power Supply"
		(exclude_from_sim no)
		(at 295.91 172.974 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "79c70b15-013d-46c9-b94c-f1d1f10d153e")
	)
	(text "ID_SD and ID_SC PINS:\nThese pins are reserved for HAT ID EEPROM.\n\nAt boot time this I2C interface will be\ninterrogated to look for an EEPROM\nthat identifes the attached board and\nallows automagic setup of the GPIOs\n(and optionally, Linux drivers).\n\nBridging JP1 enables write protection.\n\nDO NOT USE these pins for anything other\nthan attaching an I2C ID EEPROM. Leave\nunconnected if ID EEPROM not required."
		(exclude_from_sim no)
		(at 16.764 274.066 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "8714082a-55fe-4a29-9d48-99ae1ef73073")
	)
	(text "SECTION: SERVO PWM\nPCA9685: I2C 16-ch PWM @ addr 0x40\n"
		(exclude_from_sim no)
		(at 197.104 196.85 0)
		(effects
			(font
				(size 1.5 1.5)
			)
		)
		(uuid "aa905805-b67f-47da-b537-5193b9294d45")
	)
	(text "Switching Power Supply (6V/5A)"
		(exclude_from_sim no)
		(at 296.672 102.616 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "b7098227-455b-4b18-a134-b37306e9fb2b")
	)
	(text "Schmitt Trigger 6"
		(exclude_from_sim no)
		(at 297.434 209.042 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "bb395b1a-e199-4061-9d10-ecc987458023")
	)
	(text "SECTION: RELAY DRIVERS\nULN2003A: Darlington array\nIN1=GPIO17 Engine Run (magneto kill)\nIN2=GPIO27 Engine Start (momentary)\nIN3=GPIO25 Blade Relay\nCOM to +24V (flyback clamp)\nOUT1/2/3 sink relay coils to GND"
		(exclude_from_sim no)
		(at 43.39 194.84 0)
		(effects
			(font
				(size 1.5 1.5)
			)
		)
		(uuid "c2a5607a-5744-4e7f-8381-154c3b689da6")
	)
	(text "SECTION: MOTOR OPTO-ISOLATORS\nSupports 20kHz PWM switching"
