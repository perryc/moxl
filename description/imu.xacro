<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="imu">
    <!-- IMU TF frame — needed by robot_localization -->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu"/>
        <origin xyz="${robot['imu']['chip']['offset'][0]} ${robot['imu']['chip']['offset'][1]} ${robot['imu']['chip']['offset'][2]}" rpy="0 0 0"/>
    </joint>

    <link name="imu">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.005"/>
            </geometry>
            <material name="imu_grey">
                <color rgba="0.4 0.4 0.4 1"/>
            </material>
        </visual>
    </link>

    <!-- Sensor attached to base_link so it survives URDF→SDF fixed-joint merging.
         The imu link above still provides the TF frame for robot_localization. -->
    <gazebo reference="base_link">
        <sensor name="imu_sensor" type="imu">
            <gz_frame_id>imu</gz_frame_id>
            <always_on>1</always_on>
            <update_rate>50</update_rate>
            <topic>imu/data_raw</topic>
            <pose>${robot['imu']['chip']['offset'][0]} ${robot['imu']['chip']['offset'][1]} ${robot['imu']['chip']['offset'][2]} 0 0 0</pose>
        </sensor>
    </gazebo>
</robot>
